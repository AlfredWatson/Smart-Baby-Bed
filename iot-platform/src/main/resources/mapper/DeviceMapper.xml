<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.ciwater.iotplatform.dao.DeviceMapper">

    <resultMap id="deviceMap" type="Device">
        <id property="deviceId" column="sad_device_id"></id>
        <result property="deviceMac" column="sad_device_mac"></result>
    </resultMap>

    <select id="getAllDevice" resultMap="deviceMap" resultType="Device">
        select *
        from schema_iot.sensor_array_device;
    </select>

    <select id="getDeviceMac" parameterType="int" resultType="string">
        select schema_iot.sensor_array_device.sad_device_mac
        from schema_iot.sensor_array_device
        where schema_iot.sensor_array_device.sad_device_id = #{dev_id};
    </select>

    <select id="getDeviceId" parameterType="string" resultType="int">
        select schema_iot.sensor_array_device.sad_device_id
        from schema_iot.sensor_array_device
        where schema_iot.sensor_array_device.sad_device_mac = #{dev_mac};
    </select>
</mapper>
